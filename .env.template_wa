# Sama seperti service Telegram, tambah 2 variabel baru:

DATABASE_URL=postgresql://user:password@host:5432/dbname
DINOIKI_API_KEY=sk-xxxxxxxxxxxx

# Token device dari dashboard Fonnte (Settings > Device > Token)
FONNTE_TOKEN=your_fonnte_device_token_here

# Nomor WA yang diizinkan, format internasional tanpa +, pisahkan koma
# Contoh: 6281234567890,6289876543210
ALLOWED_NUMBERS=6281234567890
